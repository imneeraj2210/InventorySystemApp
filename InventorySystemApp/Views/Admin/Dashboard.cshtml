@model IEnumerable<InventorySystemApp.Models.Product>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-dark text-white">Carousel Live Control (No DB)</div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <label>Slide 1 Image URL</label>
                <input type="text" id="slide1Img" class="form-control mb-2" placeholder="Paste image link here...">
                <label>Slide 1 Title</label>
                <input type="text" id="slide1Title" class="form-control mb-2">
            </div>
            <div class="col-md-6">
                <label>Slide 2 Image URL</label>
                <input type="text" id="slide2Img" class="form-control mb-2" placeholder="Paste image link here...">
                <label>Slide 2 Title</label>
                <input type="text" id="slide2Title" class="form-control mb-2">
            </div>
        </div>
        <button onclick="saveCarouselSettings()" class="btn btn-success mt-3 w-100">Push to Live Carousel</button>
    </div>
</div>

<script>
    function saveCarouselSettings() {
        const settings = {
            s1Img: document.getElementById('slide1Img').value,
            s1Title: document.getElementById('slide1Title').value,
            s2Img: document.getElementById('slide2Img').value,
            s2Title: document.getElementById('slide2Title').value
        };
        // Saves to Browser Memory, not Backend
        localStorage.setItem('carouselSettings', JSON.stringify(settings));
        alert("Carousel Updated Locally!");
    }
</script>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Inventory Management</h2>
        <a asp-action="AddProduct" class="btn btn-success">Add New Product</a>
    </div>

    <table class="table table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Price</th>
                <th>Stock Quantity</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>
                        <span class="badge @(item.Stock < 5 ? "bg-danger" : "bg-primary")">
                            @item.Stock
                        </span>
                    </td>
                    <td>
                        @if(item.Status == "Pending")
                        {
                            <form asp-action="UpdateStatus" method="post" style="display:inline">
                                <input type="hidden" name="orderId" value="@item.Id" />
                                <button class="btn btn-success btn-sm" name="status" value="Approved">Approved</button>
                                <button class="btn btn-danger btn-sm" name="status" value="Rejected">Rejected</button>

                            </form>
                        }
                        else
                        {
                            <span>@item.Status</span>
                        }
                    </td>
                          <td>
                        <a asp-action="EditProduct" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <form asp-action="DeleteProduct" asp-route-id="@item.Id" method="post" 
                        style="display:inline" onsubmit="return confirm('Are you sure to delete this product?')">
                        <button class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
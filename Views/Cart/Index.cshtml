@model IEnumerable<InventorySystemApp.Models.Cart>

<div class="container mt-4">

    <h2>My Cart</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            Cart is empty.
        </div>
    }
    else
    {
        <table class="table table-bordered">

            <thead>
                <tr>
                    <th>Image</th>
                    <th>Product</th>
                    <th>Price</th>
                    <th>Qty</th>
                    <th>Total</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var item in Model)
                {
                    <tr>

                        <td>
                            <img src="@item.ImageUrl"
                                 style="width: 90px; height: 90px; object-fit:cover;"
                                 class="img-thumbnail" />
                        </td>

                        <td>
                            @item.ProductName
                        </td>

                        <td class="price">
                            @item.Price
                        </td>

                        <td>

                            <div class="d-flex align-items-center">

                                <button class="btn btn-outline-secondary btn-sm minus-btn"
                                        data-id="@item.Id">
                                    -
                                </button>

                                <input type="text"
                                       value="@item.Quantity"
                                       class="form-control text-center qty-input mx-2"
                                       data-id="@item.Id"
                                       style="width:60px;"
                                       readonly />

                                <button class="btn btn-outline-secondary btn-sm plus-btn"
                                        data-id="@item.Id">
                                    +
                                </button>

                            </div>

                        </td>

                        <td class="rowTotal">
                            ₹ @(item.Price * item.Quantity)
                        </td>

                        <td>

                            <form asp-action="Remove"
                                  method="post">

                                <input type="hidden"
                                       name="id"
                                       value="@item.Id" />

                                <button class="btn btn-danger btn-sm">
                                    Remove
                                </button>

                            </form>

                        </td>

                    </tr>
                }

            </tbody>

            <tfoot>

                <tr>

                    <td colspan="4"
                        class="text-end">
                        <strong>Grand Total</strong>
                    </td>

                    <td colspan="2">
                        <strong id="grandTotal">
                            ₹ @Model.Sum(x => x.Price * x.Quantity)
                        </strong>
                    </td>

                </tr>

            </tfoot>

        </table>

        <div class="mt-3 text-end">

            <button class="btn btn-success"
                    data-bs-toggle="modal"
                    data-bs-target="#checkoutModal">

                Checkout

            </button>
            <div class="modal fade"
                 id="checkoutModal"
                 tabindex="-1">

                <div class="modal-dialog">

                    <div class="modal-content">

                        <div class="modal-header">

                            <h5 class="modal-title">

                                Confirm Checkout

                            </h5>

                            <button type="button"
                                    class="btn-close"
                                    data-bs-dismiss="modal">
                            </button>

                        </div>

                        <div class="modal-body">

                            Are you sure you want to place this order?

                        </div>

                        <div class="modal-footer">

                            <button type="button"
                                    class="btn btn-secondary"
                                    data-bs-dismiss="modal">

                                Cancel

                            </button>

                            <form asp-action="Checkout"
                                  method="post">

                                <button class="btn btn-success">

                                    Confirm Checkout

                                </button>

                            </form>

                        </div>

                    </div>

                </div>

            </div>
        </div>
    }

</div>



@section Scripts {

    <script>

        $(".plus-btn").click(function () {

            var id = $(this).data("id");

            var row =
                $(this).closest("tr");

            var input =
                row.find(".qty-input");

            var qty =
                parseInt(input.val()) + 1;

            updateQty(
                id,
                qty,
                row,
                input);
        });

        $(".minus-btn").click(function () {

            var id = $(this).data("id");

            var row =
                $(this).closest("tr");

            var input =
                row.find(".qty-input");

            var qty =
                parseInt(input.val()) - 1;

            if (qty < 1)
            {
                qty = 1;
            }

            updateQty(
                id,
                qty,
                row,
                input);
        });

        function updateQty(
            id,
            qty,
            row,
            input)
        {
            $.post(
                "/Cart/UpdateQuantity",
                {
                    id: id,
                    quantity: qty
                },
                function (res)
                {
                    if (res.success)
                    {
                        input.val(qty);

                        var price =
                            parseFloat(
                                row.find(".price")
                                   .text()
                                   .replace("₹",""));

                        var total =
                            qty * price;

                        row.find(".rowTotal")
                           .text("₹ " + total);

                        var grandTotal = 0;

                        $(".rowTotal").each(function () {

                            grandTotal +=
                                parseFloat(
                                    $(this)
                                    .text()
                                    .replace("₹",""));

                        });

                        $("#grandTotal")
                            .text("₹ " + grandTotal);
                    }
                });
        }

    </script>

}
@model InventorySystemApp.Models.Product

<div class="container mt-4">

    <h2>Add Product</h2>

    <form method="post" enctype="multipart/form-data" asp-action="AddProduct">

        <div asp-validation-summary="All"
             class="text-danger mb-2">
        </div>

        <div class="mb-3">
            <label>Name</label>
            <input asp-for="Name"
                   class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Price</label>
            <input asp-for="Price"
                   class="form-control" />
            <span asp-validation-for="Price"
                  class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Stock</label>
            <input asp-for="Stock"
                   class="form-control" />
            <span asp-validation-for="Stock"
                  class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Product Image: </label>
            <input type="file" name="imageFile" class="form-control" />
        </div>

        <button type="submit"
                class="btn btn-success">
            Save
        </button>

    </form>

</div>